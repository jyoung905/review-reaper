# Review Reaper - API Keys
# Copy this to .env and fill in your keys

# Required for AI generation (dry-run mode works without it)
OPENAI_API_KEY=your_openai_api_key_here

# Admin password for dashboard
ADMIN_PASSWORD=reaper2026

# Dry-run mode (no real API calls) - set to false for production
DRY_RUN=true

# Server settings
HOST=0.0.0.0
PORT=9090

# Public base URL (set this in production, e.g. https://reviewreaper.io)
BASE_URL=http://localhost:9090

# Stripe integration
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Create a price at https://dashboard.stripe.com/products -> $97/mo recurring
STRIPE_PRICE_ID=
# Webhook secret from Stripe CLI or Stripe Dashboard webhook settings
STRIPE_WEBHOOK_SECRET=
# Set to true to require subscription for dashboard access
SUBSCRIPTION_REQUIRED=false

# SendGrid API Key for sending outreach emails
# Get yours at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here
